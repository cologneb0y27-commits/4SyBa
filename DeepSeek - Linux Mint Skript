echo ""
echo "============================================================="
echo "✅ ULTIMATE FULL SETUP ERFOLGREICH ABGESCHLOSSEN"
echo "============================================================="
cat "$REPORT"
echo ""
echo "🔁 Neustart empfohlen: sudo reboot"
echo "============================================================="

